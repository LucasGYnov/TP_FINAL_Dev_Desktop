<Window x:Class="GestionnaireLivresWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GestionnaireLivresWPF.ViewModels"
        Title="Gestionnaire de Livres WPF" Height="500" Width="850"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
            <TextBlock Text="Recherche :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="{Binding TermeRecherche, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" HorizontalAlignment="Left" Padding="2" />
            
            <Button Content="Exporter CSV" Command="{Binding ExporterCsvCommand}" 
                    HorizontalAlignment="Right" Padding="10,2"/>
        </DockPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="Détails du livre" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            
            <TextBlock Text="Titre :"/>
            <TextBox Text="{Binding Titre, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Auteur :"/>
            <TextBox Text="{Binding Auteur, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Année :"/>
            <TextBox Text="{Binding Annee, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Genre :"/>
            <ComboBox SelectedItem="{Binding Genre}" Margin="0,0,0,10">
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Roman</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">SF</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Fantasy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Policier</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Autre</System:String>
            </ComboBox>

            <CheckBox Content="Livre lu ?" IsChecked="{Binding Lu}" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Ajouter" Command="{Binding AjouterCommand}" Margin="2"/>
                <Button Content="Modifier" Grid.Column="1" Command="{Binding ModifierCommand}" Margin="2"/>
                <Button Content="Supprimer" Grid.Column="2" Command="{Binding SupprimerCommand}" Margin="2"/>
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="1" 
                  ItemsSource="{Binding Livres}" 
                  SelectedItem="{Binding LivreSelectionne}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="*"/>
                <DataGridTextColumn Header="Auteur" Binding="{Binding Auteur}" Width="*"/>
                <DataGridTextColumn Header="Année" Binding="{Binding Annee}" Width="60"/>
                <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="80"/>
                <DataGridCheckBoxColumn Header="Lu" Binding="{Binding Lu}" Width="40"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#EEEEEE" Padding="10" Margin="0,15,0,0" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding TotalLivres, StringFormat='Total : {0} livre(s)'}" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding LivresLus, StringFormat='Lus : {0}'}" Foreground="Green" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding PourcentageLus, StringFormat='Complétés : {0}%'}" Foreground="Blue" FontWeight="Bold"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>